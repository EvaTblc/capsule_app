<div class="min-h-screen pt-20 pb-24 px-4">

  <%# Header %>
  <div class="flex items-start justify-between mb-6">
    <div class="flex-1">
      <% if @event.reminder? %>
        <span class="inline-flex items-center gap-1 text-xs font-semibold text-purple-600 bg-purple-50 px-2 py-1 rounded-full mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/>
          </svg>
          Reminder
        </span>
      <% end %>
      <h1 class="text-2xl font-black tracking-tight text-gray-900"><%= @event.title %></h1>
      <p class="text-xs text-gray-400 mt-1"><%= @event.date&.strftime("%d %b %Y") %></p>
    </div>

    <div class="flex items-center gap-2 ml-4">
      <%= link_to edit_event_path(@event), class: "w-9 h-9 bg-gray-100 rounded-xl flex items-center justify-center" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
      <% end %>

      <%= button_to event_path(@event), method: :delete,
          data: { turbo_confirm: "Supprimer cet événement ?" },
          class: "w-9 h-9 bg-red-50 rounded-xl flex items-center justify-center" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
      <% end %>
    </div>
  </div>

  <%# Partager avec un ami %>
  <% if current_user.all_friends.any? %>
    <div id="share-event-<%= @event.id %>" class="mb-4">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Partager avec</p>
      <div class="flex gap-2 flex-wrap">
        <% current_user.all_friends.each do |friend| %>
          <%= button_to share_event_path(@event),
    params: { friend_id: friend.id },
    method: :post,
    data: { turbo_frame: "_top" },
    class: "flex items-center gap-2 bg-gray-50 border border-gray-100 rounded-xl px-3 py-2 text-xs font-semibold text-gray-700 active:scale-95 transition-all" do %>
            <% if friend.avatar_url.present? %>
              <img src="<%= friend.avatar_url %>" class="w-5 h-5 rounded-full object-cover">
            <% else %>
              <div class="w-5 h-5 rounded-full bg-purple-100 flex items-center justify-center">
                <span class="text-purple-600 font-bold text-xs"><%= friend.email[0].upcase %></span>
              </div>
            <% end %>
            <%= friend.email.split("@").first %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Carte Mapbox %>
  <% if @event.latitude.present? && @event.longitude.present? %>
    <div class="w-full h-48 rounded-2xl overflow-hidden mb-4"
         data-controller="map"
         data-map-api-key-value="<%= Rails.application.credentials.mapbox[:api_key] %>"
         data-map-markers-value="<%= [{ lat: @event.latitude, lng: @event.longitude, color: '#7c3aed', label: @event.title }].to_json %>"
         data-map-directions-value="<%= current_user.latitude.present? && current_user.longitude.present? %>"
         data-map-user-lat-value="<%= current_user.latitude %>"
         data-map-user-lng-value="<%= current_user.longitude %>">
    </div>
  <% end %>
  <% if @event.latitude.present? && @event.longitude.present? && current_user.latitude.present? %>
    <div id="route-info" class="flex items-center gap-2 text-sm font-semibold text-purple-600 bg-purple-50 rounded-xl px-4 py-3 mb-4">
      <span class="text-gray-400 text-xs">Calcul en cours...</span>
    </div>
  <% end %>
  <%# Adresse %>
  <% if @event.address.present? %>
    <div class="flex items-center gap-2 mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <p class="text-sm text-gray-600"><%= @event.address %></p>
    </div>
  <% end %>

  <%# Lien %>
  <% if @event.url.present? %>
    <div class="mb-4">
      <%= link_to @event.url, target: "_blank", class: "inline-flex items-center gap-2 text-sm text-purple-600 font-semibold" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
        Voir l'événement
      <% end %>
    </div>
  <% end %>

  <%# Commentaire %>
  <% if @event.comment.present? %>
    <div class="bg-gray-50 rounded-2xl p-4 mb-4">
      <p class="text-sm text-gray-700 leading-relaxed whitespace-pre-wrap"><%= @event.comment %></p>
    </div>
  <% end %>

  <%# Retour %>
  <%= link_to notes_path, class: "mt-2 flex items-center gap-2 text-sm text-gray-400 font-medium" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
    Mon Carnet
  <% end %>

</div>
