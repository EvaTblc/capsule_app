<%= form_with model: [@collection, @item], local: false, multipart: true do |f| %>

  <% book_detail       = @item.item_type == "BookDetail"      ? @item.item_detailable : nil %>
  <% video_game_detail = @item.item_type == "VideoGameDetail" ? @item.item_detailable : nil %>
  <% movie_detail      = @item.item_type == "MovieDetail"     ? @item.item_detailable : nil %>
  <% music_detail      = @item.item_type == "MusicDetail"     ? @item.item_detailable : nil %>
  <% figurine_detail   = @item.item_type == "FigurineDetail"  ? @item.item_detailable : nil %>
  <% tcg_detail        = @item.item_type == "TcgDetail"       ? @item.item_detailable : nil %>
  <% board_game_detail = @item.item_type == "BoardGameDetail" ? @item.item_detailable : nil %>

  <div data-controller="item-type games-search">

    <%= f.hidden_field :item_type, data: { item_type_target: "input" } %>

    <%# Type %>
    <label class="text-sm font-semibold text-gray-600 mb-3 block">Type</label>
    <div class="grid grid-cols-3 gap-2 mb-6">
      <% [["BookDetail", "book"], ["VideoGameDetail", "video_games"], ["MovieDetail", "movies"],
          ["MusicDetail", "music"], ["FigurineDetail", "figurines"], ["TcgDetail", "trading_cards"],
          ["BoardGameDetail", "board_games"]].each do |type, icon| %>
        <div data-item-type-target="card"
             data-type="<%= type %>"
             data-action="click->item-type#select"
             class="border-2 border-gray-100 bg-white rounded-xl p-3 flex flex-col items-center gap-2 cursor-pointer transition-all duration-150 active:scale-95">
          <%= render "collections/icons/#{icon}" %>
          <span class="text-xs font-medium text-gray-500"><%= type.gsub('Detail', '').titleize %></span>
        </div>
      <% end %>
    </div>

    <%# Champs spécifiques VideoGameDetail %>
    <div data-item-type-target="form" data-form="VideoGameDetail" class="hidden mb-4" data-controller="games-search">
      <div class="relative mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Recherche</label>
        <div class="flex gap-2">
          <input data-games-search-target="query"
                data-action="input->games-search#search"
                placeholder="Rechercher un jeu..."
                class="flex-1 border border-purple-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
          <button type="button"
                  data-action="click->games-search#startScan"
                  class="w-12 h-12 bg-purple-600 rounded-xl flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </button>
        </div>
        <div data-games-search-target="results" class="hidden absolute z-20 w-full bg-white border border-gray-100 rounded-xl shadow-lg mt-1 max-h-48 overflow-y-auto"></div>
      </div>

      <%# Scanner modal %>
      <div data-games-search-target="scanner" class="hidden fixed inset-0 z-50 bg-black flex flex-col">
        <div class="flex justify-between items-center p-4">
          <p class="text-white font-semibold">Scanner un jeu</p>
          <button type="button" data-action="click->games-search#stopScan" class="text-white text-2xl">✕</button>
        </div>
        <div class="flex-1 relative">
          <video id="game-scanner-video" class="w-full h-full object-cover"></video>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="border-2 border-purple-400 w-64 h-32 rounded-lg"></div>
          </div>
        </div>
      </div>

      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Titre</label>
        <input data-games-search-target="title" name="item[title]" placeholder="Titre de l'item..." value="<%= @item.title %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Description</label>
        <textarea data-games-search-target="description" name="video_game_detail[description]" placeholder="Description..." rows="3" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200 resize-none"><%= video_game_detail&.description %></textarea>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">État</label>
        <%= f.select :condition, ["Neuf", "Très bon état", "Bon état", "Correct", "Mauvais état"],
            { include_blank: "Sélectionner..." },
            class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-6">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Date d'acquisition</label>
        <%= f.date_field :acquired_at, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Plateforme</label>
        <input type="hidden" data-games-search-target="platform" name="video_game_detail[platform]" value="<%= video_game_detail&.platform %>">
        <div class="flex flex-wrap gap-2">
          <% ["Switch", "Switch 2", "PS1", "PS2", "PS3", "PS4", "PS5", "Xbox", "Xbox 360", "Xbox One", "Xbox Series", "Nintendo DS", "Nintendo 3DS", "Wii", "Wii U", "Gamecube", "Autres"].each do |platform| %>
            <button type="button"
                    onclick="this.closest('div').previousElementSibling || document.querySelector('[name=\'video_game_detail[platform]\']').value = '<%= platform %>'"
                    data-platform="<%= platform %>"
                    data-action="click->games-search#selectPlatform"
                    class="px-3 py-1 rounded-full text-xs font-medium border border-gray-200 text-gray-500 hover:border-purple-400 hover:text-purple-600 transition-colors duration-200 <%= video_game_detail&.platform == platform ? 'bg-purple-100 border-purple-400 text-purple-600' : 'bg-white' %>">
              <%= platform %>
            </button>
          <% end %>
        </div>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Genre</label>
        <input data-games-search-target="genre" name="video_game_detail[genre]" placeholder="Genre" value="<%= video_game_detail&.genre %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Développeur</label>
        <input data-games-search-target="developer" name="video_game_detail[developer]" placeholder="Développeur" value="<%= video_game_detail&.developer %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Année de sortie</label>
        <input data-games-search-target="release_date" name="video_game_detail[release_date]" type="number" value="<%= video_game_detail&.release_date %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>

      <div class="mb-4 flex items-center gap-3">
        <input type="checkbox" name="video_game_detail[completed]" id="completed" value="1"
              <%= "checked" if video_game_detail&.completed? %>
              class="w-5 h-5 rounded accent-purple-600 cursor-pointer">
        <label for="completed" class="text-sm font-semibold text-gray-600 cursor-pointer">Jeu complet avec notice ?</label>
      </div>
    </div>

    <%# Champs spécifiques BookDetail %>
    <div data-item-type-target="form" data-form="BookDetail" class="hidden mb-4" data-controller="book-search">
      <div class="relative mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Recherche</label>
        <div class="flex gap-2">
          <input data-book-search-target="query"
                data-action="input->book-search#search"
                placeholder="Rechercher un livre..."
                class="flex-1 border border-purple-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
          <button type="button"
                  data-action="click->book-search#startScan"
                  class="w-12 h-12 bg-purple-600 rounded-xl flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </button>
        </div>
        <div data-book-search-target="results" class="hidden absolute z-20 w-full bg-white border border-gray-100 rounded-xl shadow-lg mt-1 max-h-48 overflow-y-auto"></div>
      </div>

      <%# Scanner modal %>
      <div data-book-search-target="scanner" class="hidden fixed inset-0 z-50 bg-black flex flex-col">
        <div class="flex justify-between items-center p-4">
          <p class="text-white font-semibold">Scanner un ISBN</p>
          <button type="button" data-action="click->book-search#stopScan" class="text-white text-2xl">✕</button>
        </div>
        <div id="book-scanner-viewport" class="flex-1 relative">
          <video id="book-scanner-video" class="w-full h-full object-cover"></video>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="border-2 border-purple-400 w-64 h-32 rounded-lg"></div>
          </div>
        </div>
      </div>

      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Titre</label>
        <input data-book-search-target="title" name="item[title]" placeholder="Titre de l'item..." value="<%= @item.title %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">État</label>
        <%= f.select :condition, ["Neuf", "Très bon état", "Bon état", "Correct", "Mauvais état"], { include_blank: "Sélectionner..." }, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Date d'acquisition</label>
        <%= f.date_field :acquired_at, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>

      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Description</label>
        <textarea data-book-search-target="description" name="book_detail[description]" placeholder="Description..." rows="3" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200 resize-none"><%= book_detail&.description %></textarea>
      </div>

      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Auteur</label>
        <input data-book-search-target="author" name="book_detail[author]" placeholder="Auteur" value="<%= book_detail&.author %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">ISBN</label>
        <input data-book-search-target="isbn" name="book_detail[isbn]" placeholder="ISBN" value="<%= book_detail&.isbn %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Éditeur</label>
        <input data-book-search-target="publisher" name="book_detail[publisher]" placeholder="Éditeur" value="<%= book_detail&.publisher %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Pages</label>
        <input data-book-search-target="pages" name="book_detail[pages]" type="number" placeholder="Nombre de pages" value="<%= book_detail&.pages %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Genre</label>
        <input data-book-search-target="genre" name="book_detail[genre]" placeholder="Genre" value="<%= book_detail&.genre %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
    </div>

    <%# Champs spécifiques MovieDetail %>
    <div data-item-type-target="form" data-form="MovieDetail" class="hidden mb-4" data-controller="movie-search">
      <div class="relative mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Recherche</label>
        <div class="flex gap-2">
          <input data-movie-search-target="query"
                data-action="input->movie-search#search"
                placeholder="Rechercher un film..."
                class="flex-1 border border-purple-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
          <button type="button"
                  data-action="click->movie-search#startScan"
                  class="w-12 h-12 bg-purple-600 rounded-xl flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </button>
        </div>
        <div data-movie-search-target="results" class="hidden absolute z-20 w-full bg-white border border-gray-100 rounded-xl shadow-lg mt-1 max-h-48 overflow-y-auto"></div>
      </div>

      <%# Scanner modal %>
      <div data-movie-search-target="scanner" class="hidden fixed inset-0 z-50 bg-black flex flex-col">
        <div class="flex justify-between items-center p-4">
          <p class="text-white font-semibold">Scanner un film</p>
          <button type="button" data-action="click->movie-search#stopScan" class="text-white text-2xl">✕</button>
        </div>
        <div class="flex-1 relative">
          <video id="movie-scanner-video" class="w-full h-full object-cover"></video>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="border-2 border-purple-400 w-64 h-32 rounded-lg"></div>
          </div>
        </div>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Titre</label>
        <input data-movie-search-target="title" name="item[title]" placeholder="Titre de l'item..." value="<%= @item.title %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">État</label>
        <%= f.select :condition, ["Neuf", "Très bon état", "Bon état", "Correct", "Mauvais état"], { include_blank: "Sélectionner..." }, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Date d'acquisition</label>
        <%= f.date_field :acquired_at, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Description</label>
        <textarea data-movie-search-target="description" name="movie_detail[description]" placeholder="Description..." rows="3" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200 resize-none"><%= movie_detail&.description %></textarea>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Réalisateur</label>
        <input data-movie-search-target="director" name="movie_detail[director]" placeholder="Réalisateur" value="<%= movie_detail&.director %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Année</label>
        <input data-movie-search-target="year" name="movie_detail[year]" type="number" placeholder="Année" value="<%= movie_detail&.year %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Studio</label>
        <input data-movie-search-target="studio" name="movie_detail[studio]" placeholder="Studio" value="<%= movie_detail&.studio %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Format</label>
        <input name="movie_detail[format]" placeholder="Format (DVD, Blu-ray...)" value="<%= movie_detail&.format %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
    </div>

    <%# Champs spécifiques MusicDetail %>
    <div data-item-type-target="form" data-form="MusicDetail" class="hidden mb-4" data-controller="music-search">
      <div class="relative mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Recherche</label>
        <input data-music-search-target="query"
              data-action="input->music-search#search"
              placeholder="Rechercher un album..."
              class="w-full border border-purple-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
        <div data-music-search-target="results" class="hidden absolute z-20 w-full bg-white border border-gray-100 rounded-xl shadow-lg mt-1 max-h-48 overflow-y-auto"></div>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Titre</label>
        <input data-music-search-target="title" name="item[title]" placeholder="Titre de l'item..." value="<%= @item.title %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">État</label>
        <%= f.select :condition, ["Neuf", "Très bon état", "Bon état", "Correct", "Mauvais état"], { include_blank: "Sélectionner..." }, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Date d'acquisition</label>
        <%= f.date_field :acquired_at, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Artiste</label>
        <input data-music-search-target="artist" name="music_detail[artist]" placeholder="Artiste" value="<%= music_detail&.artist %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Album</label>
        <input name="music_detail[album]" placeholder="Album" value="<%= music_detail&.album %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Année</label>
        <input data-music-search-target="year" name="music_detail[year]" type="number" placeholder="Année" value="<%= music_detail&.year %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Label</label>
        <input data-music-search-target="label" name="music_detail[label]" placeholder="Label" value="<%= music_detail&.label %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Format</label>
        <input data-music-search-target="format" name="music_detail[format]" placeholder="Format (CD, Vinyl...)" value="<%= music_detail&.format %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Genre</label>
        <input data-music-search-target="genre" name="music_detail[genre]" placeholder="Genre" value="<%= music_detail&.genre %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
    </div>

    <%# Champs spécifiques FigurineDetail %>
    <div data-item-type-target="form" data-form="FigurineDetail" class="hidden mb-4"
        data-controller="figurine-identify">

      <%# Bouton photo d'identification %>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Identifier par photo</label>
        <div class="flex gap-2">
          <input type="file" accept="image/*" capture="environment"
                class="hidden" id="figurine-identify-input"
                data-figurine-identify-target="input"
                data-action="change->figurine-identify#identify">
          <label for="figurine-identify-input"
                class="flex-1 flex items-center justify-center gap-2 py-3 rounded-xl border border-purple-300 text-sm font-medium text-purple-600 cursor-pointer hover:border-purple-400 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Identifier ma figurine
          </label>
        </div>
        <div data-figurine-identify-target="loader" class="hidden mt-2 text-sm text-purple-500 text-center">
          ✨ Identification en cours...
        </div>
      </div>

      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Titre</label>
        <%= f.text_field :title, placeholder: "Titre de l'item...",
            data: { "figurine-identify-target": "title" },
            class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
            <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Personnage</label>
        <input name="figurine_detail[name]" placeholder="Nom du personnage" value="<%= figurine_detail&.name %>"
              data-figurine-identify-target="name"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Série / Franchise</label>
        <input name="figurine_detail[series]" placeholder="Dragon Ball, Marvel..." value="<%= figurine_detail&.series %>"
              data-figurine-identify-target="series"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Fabricant</label>
        <input name="figurine_detail[manufacturer]" placeholder="Funko, Bandai, Kotobukiya..." value="<%= figurine_detail&.manufacturer %>"
              data-figurine-identify-target="manufacturer"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Gamme</label>
        <input name="figurine_detail[line]" placeholder="Figuarts, Pop!, Nendoroid..." value="<%= figurine_detail&.line %>"
              data-figurine-identify-target="line"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Édition</label>
        <%= f.select :edition, FigurineDetail::EDITION,
            { include_blank: "Sélectionner..." },
            class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Année de sortie</label>
        <input name="figurine_detail[release_year]" type="number" placeholder="2024" value="<%= figurine_detail&.release_year %>"
              data-figurine-identify-target="release_year"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>

      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">État</label>
        <%= f.select :condition, FigurineDetail::CONDITION,
            { include_blank: "Sélectionner..." },
            class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Date d'acquisition</label>
        <%= f.date_field :acquired_at, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">État de la boîte</label>
        <input name="figurine_detail[condition_box]" placeholder="Neuve, Ouverte, Abîmée..." value="<%= figurine_detail&.condition_box %>"
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4 flex items-center gap-3">
        <input type="checkbox" name="figurine_detail[is_complete]" id="figurine_is_complete" value="1"
              <%= "checked" if figurine_detail&.is_complete? %>
              class="w-5 h-5 rounded accent-purple-600 cursor-pointer">
        <label for="figurine_is_complete" class="text-sm font-semibold text-gray-600 cursor-pointer">Figurine complète avec accessoires ?</label>
      </div>
    </div>

    <%# Champs spécifiques TcgDetail %>
    <div data-item-type-target="form" data-form="TcgDetail" class="hidden mb-4">
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Titre</label>
        <%= f.text_field :title, placeholder: "Titre de l'item...", class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">État</label>
        <%= f.select :condition, ["Neuf", "Très bon état", "Bon état", "Correct", "Mauvais état"], { include_blank: "Sélectionner..." }, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Date d'acquisition</label>
        <%= f.date_field :acquired_at, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Jeu</label>
        <input name="tcg_detail[game]" placeholder="Jeu (Pokemon, Magic...)" value="<%= tcg_detail&.game %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Set</label>
        <input name="tcg_detail[card_set]" placeholder="Set" value="<%= tcg_detail&.card_set %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Numéro de carte</label>
        <input name="tcg_detail[card_number]" placeholder="Numéro de carte" value="<%= tcg_detail&.card_number %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Rareté</label>
        <input name="tcg_detail[rarity]" placeholder="Rareté" value="<%= tcg_detail&.rarity %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
    </div>

    <%# Champs spécifiques BoardGameDetail %>
    <div data-item-type-target="form" data-form="BoardGameDetail" class="hidden mb-4">
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Titre</label>
        <%= f.text_field :title, placeholder: "Titre de l'item...", class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">État</label>
        <%= f.select :condition, ["Neuf", "Très bon état", "Bon état", "Correct", "Mauvais état"], { include_blank: "Sélectionner..." }, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Date d'acquisition</label>
        <%= f.date_field :acquired_at, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Éditeur</label>
        <input name="board_game_detail[publisher]" placeholder="Éditeur" value="<%= board_game_detail&.publisher %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Joueurs min</label>
        <input name="board_game_detail[min_players]" type="number" placeholder="Joueurs min" value="<%= board_game_detail&.min_players %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Joueurs max</label>
        <input name="board_game_detail[max_players]" type="number" placeholder="Joueurs max" value="<%= board_game_detail&.max_players %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Durée (minutes)</label>
        <input name="board_game_detail[duration]" type="number" placeholder="Durée" value="<%= board_game_detail&.duration %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
    </div>

    <div class="mb-6">
      <label class="text-sm font-semibold text-gray-600 mb-1 block">Commentaire</label>
      <textarea name="item[comment]" placeholder="Un commentaire sur cet item..." rows="2"
                class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200 resize-none"><%= @item.comment %></textarea>
    </div>

    <%# Images %>
    <div class="mb-6">

    <div class="mb-6" data-controller="image-preview">

      <%# Miniatures existantes %>
      <% if @item.persisted? && @item.images.attached? %>
        <div class="grid grid-cols-3 gap-2 mb-3">
          <% @item.images.each do |image| %>
            <%= link_to collection_item_path(@collection, @item, remove_image: image.id),
                data: { turbo_method: :patch, turbo_confirm: "Supprimer cette image ?" } do %>
              <div class="relative h-24 rounded-xl overflow-hidden">
                <%= image_tag image, class: "w-full h-full object-cover" %>
                <div class="absolute inset-0 flex items-center justify-center" style="background: rgba(0,0,0,0.4)">
                  <span class="text-white text-lg">🗑</span>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <%# Preview des nouvelles images %>
      <div data-image-preview-target="preview" class="grid grid-cols-3 gap-2 mb-3"></div>

          <%# Inputs %>
          <div class="flex gap-2">
            <input type="file" accept="image/*" capture="environment" name="item[images][]"
                  class="hidden" id="camera-input"
                  data-action="change->image-preview#preview">
            <input type="file" accept="image/*" multiple name="item[images][]"
                  class="hidden" id="gallery-input"
                  data-action="change->image-preview#preview">

            <label for="camera-input" class="flex-1 flex items-center justify-center gap-2 py-3 rounded-xl border border-gray-200 text-sm font-medium text-gray-600 cursor-pointer hover:border-purple-400 hover:text-purple-600 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Caméra
            </label>

            <label for="gallery-input" class="flex-1 flex items-center justify-center gap-2 py-3 rounded-xl border border-gray-200 text-sm font-medium text-gray-600 cursor-pointer hover:border-purple-400 hover:text-purple-600 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              Galerie
            </label>
          </div>
        </div>

        <%= f.submit "Valider", class: "w-full bg-purple-600 text-white font-semibold py-3 rounded-xl shadow-md shadow-purple-200 active:scale-95 transition-transform duration-150 mt-2" %>

    </div>
  <% end %>
