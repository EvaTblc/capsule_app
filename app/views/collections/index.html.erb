<div class="min-h-screen p-4 pt-20 pb-24">

  <% if @collections.empty? %>
    <div class="flex flex-col items-center justify-center min-h-96 gap-4 text-center">
      <div class="w-20 h-20 bg-purple-50 rounded-3xl flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-purple-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-black tracking-tight text-gray-900 mb-1">Aucune collection</h2>
        <p class="text-sm text-gray-400">Crée ta première collection pour commencer à cataloguer tes objets.</p>
      </div>
      <%= link_to new_collection_path, class: "bg-purple-600 text-white px-6 py-3 rounded-xl font-semibold text-sm" do %>
        Créer une collection
      <% end %>
    </div>

  <% else %>

    <%# Récemment ajouté %>
    <% recent_items = @collections.flat_map(&:items).sort_by(&:created_at).last(6).reverse %>
    <% if recent_items.any? %>
      <div class="mb-6">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Récemment ajouté</h2>
        <div style="display: flex; gap: 12px; overflow-x: auto; padding-bottom: 8px; scrollbar-width: none;">
          <% recent_items.each do |item| %>
            <%= link_to collection_item_path(item.collection, item), style: "flex-shrink: 0; width: 112px; text-decoration: none;" do %>
              <div style="width: 112px; height: 144px; border-radius: 16px; overflow: hidden; background: #f3f4f6; margin-bottom: 8px;">
                <% if item.images.attached? %>
                  <%= image_tag item.images.first, style: "width: 112px; height: 144px; object-fit: cover; display: block;" %>
                <% elsif item.collection.cover_image.attached? %>
                  <%= image_tag item.collection.cover_image, style: "width: 112px; height: 144px; object-fit: cover; object-position: top; display: block;" %>
                <% else %>
                  <div style="width: 100%; height: 100%; background: #ede9fe; display: flex; align-items: flex-end; padding: 8px; box-sizing: border-box;">
                    <p style="font-size: 11px; font-weight: 700; color: #4b5563; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;"><%= item.title %></p>
                  </div>
                <% end %>
              </div>
              <p style="font-size: 11px; font-weight: 600; color: #1f2937; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; width: 112px;"><%= item.title %></p>
              <p style="font-size: 11px; color: #9ca3af; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; width: 112px;"><%= item.collection.title %></p>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Grille collections %>
    <h1 class="text-2xl font-black tracking-tight mb-4">Mes collections</h1>
    <div class="grid grid-cols-2 gap-4">
      <% @collections.sort.each do |collection| %>
        <%= link_to collection_path(collection) do %>
          <div class="rounded-2xl p-4 shadow-md active:scale-95 transition-transform duration-150 relative overflow-hidden min-h-32
                      <%= collection.cover_image.attached? ? 'h-36' : Collection::CATEGORY_STYLES[collection.category] %>"
               style="<%= collection.cover_image.attached? ? "background-image: url('#{url_for(collection.cover_image)}'); background-size: cover; background-position: center;" : "" %>">
            <% if collection.cover_image.attached? %>
              <div class="absolute inset-0 bg-black opacity-40 rounded-2xl"></div>
            <% end %>
            <div class="relative z-10 h-full flex flex-col justify-between">
              <div class="w-8 h-8 bg-white rounded-lg flex items-center justify-center shadow-sm">
                <%= render "collections/icons/#{collection.category == 'books' ? 'book' : collection.category}" %>
              </div>
              <div>
                <h2 class="text-lg font-bold <%= collection.cover_image.attached? ? 'text-white' : '' %>"><%= collection.title %></h2>
                <p class="text-xs <%= collection.cover_image.attached? ? 'text-white opacity-75' : 'text-gray-400' %>"><%= collection.items.count %> items</p>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

  <% end %>

</div>

<% unless @collections.empty? %>
  <%= link_to new_collection_path, class: "fixed bottom-24 right-6 z-10 bg-purple-600 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg shadow-purple-300 hover:bg-purple-700 transition-colors duration-200" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
    </svg>
  <% end %>
<% end %>
