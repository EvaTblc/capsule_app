<%= turbo_frame_tag "events-section" do %>
  <% if events.empty? %>
    <div class="flex flex-col items-center justify-center gap-3 text-center bg-gray-50 rounded-2xl py-12 mb-6">
      <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-purple-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
      <div>
        <h2 class="text-sm font-black text-gray-900">Aucun événement</h2>
        <p class="text-xs text-gray-400 mt-1">Ajoute tes vide-greniers et brocantes à venir</p>
      </div>
    </div>
  <% else %>
    <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3 mt-2">Événements</h2>
    <div class="flex flex-col gap-2 mb-4">
      <% events.sort_by { |e| e.date || Date::Infinity.new }.each do |event| %>
        <%= link_to event_path(event), data: { turbo_frame: "_top" } do %>
          <div class="bg-white border border-gray-100 rounded-2xl px-4 py-3 flex items-center gap-3 active:scale-95 transition-transform duration-150">
            <div class="w-9 h-9 rounded-xl <%= event.reminder? ? 'bg-purple-50' : 'bg-gray-50' %> flex items-center justify-center shrink-0 flex-col">
              <p class="text-xs font-black text-gray-700 leading-none"><%= event.date&.strftime("%d") %></p>
              <p class="text-xs text-gray-400 leading-none uppercase"><%= event.date&.strftime("%b") %></p>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate"><%= event.title %></p>
              <p class="text-xs text-gray-400 truncate"><%= event.address %></p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        <% end %>
      <% end %>
    </div>

    <% if current_user.address.present? %>
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Carte</h2>
      <div style="width: 100%; height: 224px;"
          class="rounded-2xl overflow-hidden mb-4"
          data-controller="map"
          data-map-markers-value="<%= markers.to_json %>"
          data-map-api-key-value="<%= Rails.application.credentials.mapbox[:api_key] %>"
          data-map-user-lat-value="<%= current_user.latitude.to_f %>"
          data-map-user-lng-value="<%= current_user.longitude.to_f %>">
      </div>
    <% end %>
  <% end %>
<% end %>
