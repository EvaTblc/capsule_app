<div class="min-h-screen p-4 pt-20 pb-24">

  <h1 class="text-2xl font-black tracking-tight mb-6">Mon Carnet</h1>

  <%# NOTES %>
  <% if @notes.empty? %>
    <div class="flex flex-col items-center justify-center gap-3 text-center bg-gray-50 rounded-2xl p-8 mb-8">
      <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-purple-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
      </div>
      <div>
        <h2 class="text-sm font-black text-gray-900">Aucune note</h2>
        <p class="text-xs text-gray-400 mt-1">Note tes recherches, idées, wishlists...</p>
      </div>
    </div>
  <% else %>
    <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Notes</h2>
    <div class="flex flex-col gap-2 mb-6">
      <% @notes.each do |note| %>
        <%= link_to note_path(note) do %>
          <div class="bg-white border border-gray-100 rounded-2xl px-4 py-3 flex items-center gap-3 active:scale-95 transition-transform duration-150">
            <div class="w-9 h-9 rounded-xl <%= note.reminder? ? 'bg-purple-50' : 'bg-gray-50' %> flex items-center justify-center shrink-0">
              <% if note.reminder? %>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-purple-400" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/>
                </svg>
              <% else %>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
              <% end %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate"><%= note.title %></p>
              <p class="text-xs text-gray-400 truncate"><%= note.comment&.truncate(40) %></p>
              <% if note.collection.present? %>
                <p class="text-xs text-purple-400 truncate"><%= note.collection.title %></p>
              <% end %>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%# EVENTS %>
  <%= turbo_frame_tag "events-section" do %>
    <% if @events.empty? %>
      <div class="flex flex-col items-center justify-center gap-3 text-center bg-gray-50 rounded-2xl py-12 mb-6">
        <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-purple-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <div>
          <h2 class="text-sm font-black text-gray-900">Aucun événement</h2>
          <p class="text-xs text-gray-400 mt-1">Ajoute tes vide-greniers et brocantes à venir</p>
        </div>
      </div>
    <% else %>
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3 mt-2">Événements</h2>
      <div class="flex flex-col gap-2 mb-4">
        <% @events.sort_by { |e| e.date || Date::Infinity.new }.each do |event| %>
          <%= link_to event_path(event), data: { turbo_frame: "_top" } do %>
            <div class="bg-white border border-gray-100 rounded-2xl px-4 py-3 flex items-center gap-3 active:scale-95 transition-transform duration-150">
              <div class="w-9 h-9 rounded-xl <%= event.reminder? ? 'bg-purple-50' : 'bg-gray-50' %> flex items-center justify-center shrink-0 flex-col">
                <p class="text-xs font-black text-gray-700 leading-none"><%= event.date&.strftime("%d") %></p>
                <p class="text-xs text-gray-400 leading-none uppercase"><%= event.date&.strftime("%b") %></p>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-900 truncate"><%= event.title %></p>
                <p class="text-xs text-gray-400 truncate"><%= event.address %></p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          <% end %>
        <% end %>
      </div>

      <%# Carte %>
      <% if current_user.address.present? %>
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Carte</h2>
        <div style="width: 100%; height: 224px;"
            class="rounded-2xl overflow-hidden mb-4"
            data-controller="map"
            data-map-markers-value="<%= @markers.to_json %>"
            data-map-api-key-value="<%= Rails.application.credentials.mapbox[:api_key] %>"
            data-map-user-lat-value="<%= current_user.latitude.to_f %>"
            data-map-user-lng-value="<%= current_user.longitude.to_f %>">
        </div>
      <% end %>
    <% end %>
  <% end %>

  <%# Bouton scraper — toujours visible, en dehors du frame %>
  <% if current_user.address.present? %>
    <%= button_to list_events_path, method: :post,
        class: "w-full flex items-center justify-center gap-2 bg-purple-50 border border-purple-100 text-purple-600 py-3 rounded-2xl text-sm font-semibold mb-6 active:scale-95 transition-all duration-150" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      Trouver des événements près de moi
    <% end %>
  <% else %>
    <%= link_to profile_path, data: { turbo_frame: "_top" },
        class: "w-full flex items-center justify-center gap-2 bg-purple-50 border border-purple-100 text-purple-600 py-3 rounded-2xl text-sm font-semibold mb-6 active:scale-95 transition-all duration-150" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      Enregistrer une adresse pour trouver des événements près de chez vous
    <% end %>
  <% end %>

</div>

<%# FAB %>
<%= link_to new_note_path, class: "fixed bottom-24 right-6 z-10 bg-purple-600 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg shadow-purple-300 hover:bg-purple-700 transition-colors duration-200" do %>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
  </svg>
<% end %>
