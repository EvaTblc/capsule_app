<div class="min-h-screen p-4">
  <h1 class="text-2xl font-black tracking-tight mb-6">Mes collections</h1>

  <div class="flex gap-4 mb-6">
    <div class="bg-purple-50 rounded-2xl px-4 py-3 flex-1 text-center">
      <p class="text-2xl font-black text-purple-600"><%= @collections.count %></p>
      <p class="text-xs text-gray-400 mt-1">Collections</p>
    </div>
    <div class="bg-purple-50 rounded-2xl px-4 py-3 flex-1 text-center">
      <p class="text-2xl font-black text-purple-600"><%= @collections.sum { |c| c.items.count } %></p>
      <p class="text-xs text-gray-400 mt-1">Items</p>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <% @collections.each do |collection| %>
      <%= link_to collection_path(collection) do %>
        <div class="rounded-2xl p-4 shadow-md active:scale-95 transition-transform duration-150 relative overflow-hidden min-h-32
                    <%= collection.cover_image.attached? ? 'h-36' : Collection::CATEGORY_STYLES[collection.category] %>"
             style="<%= collection.cover_image.attached? ? "background-image: url('#{url_for(collection.cover_image)}'); background-size: cover; background-position: center;" : "" %>">

          <% if collection.cover_image.attached? %>
            <div class="absolute inset-0 bg-black opacity-40 rounded-2xl"></div>
          <% end %>

          <div class="relative z-10">
            <div class="w-8 h-8 bg-white rounded-lg flex items-center justify-center shadow-sm mb-2">
              <%= render "collections/icons/#{collection.category == 'books' ? 'book' : collection.category}" %>
            </div>
            <h2 class="text-lg font-bold mt-3 <%= collection.cover_image.attached? ? 'text-white' : '' %>"><%= collection.title %></h2>
            <p class="text-xs mt-2 <%= collection.cover_image.attached? ? 'text-white opacity-75' : 'text-gray-400' %>"><%= collection.items.count %> items</p>
          </div>

        </div>
      <% end %>
    <% end %>
  </div>

</div>

<%= link_to new_collection_path, class: "fixed bottom-24 right-6 z-10 bg-purple-600 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg shadow-purple-300 hover:bg-purple-700 transition-colors duration-200" do %>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
  </svg>
<% end %>
