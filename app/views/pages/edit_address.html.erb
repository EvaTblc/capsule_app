<%= turbo_frame_tag "address" do %>
  <div class="flex flex-col gap-4">
    <%= form_with model: current_user, url: update_address_path, method: :patch, class: "flex flex-col gap-4" do |f| %>
      <div>
        <%= f.text_field :address,
            placeholder: "Ex: Nantes, Loire-Atlantique",
            class: "w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 outline-none focus:ring-2 focus:ring-purple-300" %>
      </div>
      <%= f.submit "Enregistrer", class: "w-full bg-purple-600 text-white py-3 rounded-xl font-semibold text-sm hover:bg-purple-700 transition-colors duration-200" %>
    <% end %>
  </div>
<% end %>
