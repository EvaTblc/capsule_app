<div class="min-h-screen flex flex-col items-center justify-center bg-white px-14">
  <div class="w-full max-w-xs">

    <div class="text-center mb-10">
      <h1 class="text-7xl font-black tracking-tight text-gray-900 mb-4">Capsule</h1>
      <p class="text-sm text-gray-500">Vos collections dans votre poche.</p>
    </div>

    <a href="/users/auth/google_oauth2" class="w-full flex items-center justify-center gap-3 py-3 px-4 rounded-xl border border-gray-200 bg-white text-gray-800 font-medium text-sm hover:bg-gray-50 transition-colors cursor-pointer">
      <svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Continuer avec Google
    </a>

    <div class="relative my-6">
      <div class="absolute inset-0 flex items-center">
        <div class="border-t border-gray-200 w-full"></div>
      </div>
      <div class="relative flex justify-center">
        <span class="bg-white px-3 text-xs text-gray-400">ou</span>
      </div>
    </div>

    <%= form_with(model: resource, as: resource_name, url: session_path(resource_name), local: true) do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :email, "Email", class: "block text-xs font-medium text-gray-700 mb-1.5" %>
          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "vous@exemple.fr",
              class: "w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-shadow" %>
        </div>
        <div>
          <div class="flex items-center justify-between mb-1.5">
            <%= f.label :password, "Mot de passe", class: "block text-xs font-medium text-gray-700" %>
            <%= link_to "Mot de passe oublié ?", new_user_password_path,
                class: "text-xs text-purple-600 hover:text-purple-700 transition-colors" %>
          </div>
          <%= f.password_field :password,
              autocomplete: "current-password",
              placeholder: "••••••••",
              class: "w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-shadow" %>
        </div>
      </div>

      <div class="mt-6">
        <%= f.submit "Se connecter",
            class: "w-full py-3 rounded-xl bg-purple-600 hover:bg-purple-700 text-white font-medium text-sm transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <p class="mt-6 text-center text-sm text-gray-500">
      Pas encore de compte ?
      <%= link_to "Créer un compte", new_user_registration_path,
          class: "text-purple-600 hover:text-purple-700 font-medium transition-colors" %>
    </p>

  </div>
</div>
