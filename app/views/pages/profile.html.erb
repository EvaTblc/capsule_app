<div class="min-h-screen p-4 pt-20 pb-24">

  <%# Avatar + Infos %>
  <div class="flex items-center gap-4 mb-8">
    <% if current_user.avatar_url %>
      <img src="<%= current_user.avatar_url %>" class="w-16 h-16 rounded-full object-cover">
    <% else %>
      <div class="w-16 h-16 rounded-full bg-purple-100 flex items-center justify-center">
        <span class="text-purple-600 font-bold text-xl"><%= current_user.email[0].upcase %></span>
      </div>
    <% end %>
    <div>
      <h1 class="text-2xl font-black tracking-tight"><%= current_user.email.split("@").first %></h1>
      <p class="text-sm text-gray-400"><%= current_user.email %></p>
    </div>
  </div>

  <%# Adresse %>
  <div class="mb-8">
    <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Mon adresse</h2>
    <%= turbo_frame_tag "address" do %>
      <% if current_user.address.present? %>
        <div class="bg-gray-50 rounded-2xl p-4 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-purple-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="text-sm text-gray-700 font-medium"><%= current_user.address %></p>
          </div>
          <%= link_to edit_address_path, class: "text-xs text-purple-600 font-semibold" do %>
            Modifier
          <% end %>
        </div>
      <% else %>
        <%= link_to edit_address_path, class: "w-full flex items-center justify-center gap-2 border border-dashed border-purple-200 bg-purple-50 text-purple-600 py-3 rounded-2xl text-sm font-semibold" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          Ajouter mon adresse
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%# Amis %>
  <div class="mb-8">
    <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Mes amis</h2>
    <% if @friends.any? %>
      <div class="flex flex-col gap-2">
        <% @friends.each do |friend| %>
          <div class="bg-white border border-gray-100 rounded-2xl px-4 py-3 flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-purple-100 flex items-center justify-center shrink-0">
              <% if friend.avatar_url.present? %>
                <img src="<%= friend.avatar_url %>" class="w-9 h-9 rounded-full object-cover">
              <% else %>
                <span class="text-purple-600 font-bold text-sm"><%= friend.email[0].upcase %></span>
              <% end %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate"><%= friend.email.split("@").first %></p>
              <p class="text-xs text-gray-400 truncate"><%= friend.email %></p>
            </div>
            <%= button_to friendship_path(current_user.sent_friendships.find_by(receiver: friend) || current_user.received_friendships.find_by(requester: friend)),
                method: :delete,
                class: "text-xs text-red-400 font-semibold" do %>
              Retirer
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-gray-50 rounded-2xl px-4 py-6 text-center">
        <p class="text-sm font-semibold text-gray-900">Aucun ami pour l'instant</p>
        <p class="text-xs text-gray-400 mt-1">Recherche un ami par email ci-dessous</p>
      </div>
    <% end %>
    <% if @sent_friendships.any? %>
      <div class="mb-8">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Demandes envoyées</h2>
        <div class="flex flex-col gap-2">
          <% @sent_friendships.each do |friendship| %>
            <div class="bg-white border border-gray-100 rounded-2xl px-4 py-3 flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-purple-100 flex items-center justify-center shrink-0">
                <% if friendship.receiver.avatar_url.present? %>
                  <img src="<%= friendship.receiver.avatar_url %>" class="w-9 h-9 rounded-full object-cover">
                <% else %>
                  <span class="text-purple-600 font-bold text-sm"><%= friendship.receiver.email[0].upcase %></span>
                <% end %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-900 truncate"><%= friendship.receiver.email.split("@").first %></p>
                <p class="text-xs text-gray-400">En attente...</p>
              </div>
              <%= button_to friendship_path(friendship), method: :delete,
                  class: "text-xs text-gray-400 font-semibold" do %>
                Annuler
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Recherche par email %>
    <div class="mt-3">
      <%= form_with url: friendships_path, method: :post, class: "flex gap-2" do |f| %>
        <%= f.email_field :receiver_email,
            placeholder: "Email de ton ami",
            class: "flex-1 bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 outline-none focus:ring-2 focus:ring-purple-300" %>
        <%= f.submit "Ajouter", class: "bg-purple-600 text-white px-4 py-3 rounded-xl text-sm font-semibold" %>
      <% end %>
    </div>
  </div>

  <%# Demandes reçues %>
  <% if @pending_friendships.any? %>
    <div class="mb-8">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Demandes reçues</h2>
      <div class="flex flex-col gap-2">
        <% @pending_friendships.each do |friendship| %>
          <div class="bg-white border border-gray-100 rounded-2xl px-4 py-3 flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-purple-100 flex items-center justify-center shrink-0">
              <% if friendship.requester.avatar_url.present? %>
                <img src="<%= friendship.requester.avatar_url %>" class="w-9 h-9 rounded-full object-cover">
              <% else %>
                <span class="text-purple-600 font-bold text-sm"><%= friendship.requester.email[0].upcase %></span>
              <% end %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate"><%= friendship.requester.email.split("@").first %></p>
              <p class="text-xs text-gray-400 truncate"><%= friendship.requester.email %></p>
            </div>
            <div class="flex gap-2">
              <%= button_to accept_friendship_path(friendship), method: :patch,
                  class: "bg-purple-600 text-white px-3 py-1.5 rounded-xl text-xs font-semibold" do %>
                Accepter
              <% end %>
              <%= button_to reject_friendship_path(friendship), method: :patch,
                  class: "bg-gray-100 text-gray-500 px-3 py-1.5 rounded-xl text-xs font-semibold" do %>
                Refuser
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Stats collections %>
  <div class="mb-8">
    <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Stats</h2>
    <div class="flex gap-3">
      <div class="bg-purple-50 rounded-2xl px-4 py-3 flex-1 text-center">
        <p class="text-2xl font-black text-purple-600"><%= @collections_owned.count %></p>
        <p class="text-xs text-gray-400 mt-1">Collections</p>
      </div>
      <div class="bg-purple-50 rounded-2xl px-4 py-3 flex-1 text-center">
        <p class="text-2xl font-black text-purple-600"><%= @collections_shared.count %></p>
        <p class="text-xs text-gray-400 mt-1">Partagées</p>
      </div>
      <div class="bg-purple-50 rounded-2xl px-4 py-3 flex-1 text-center">
        <p class="text-2xl font-black text-purple-600"><%= @collections_owned.sum { |c| c.items.size } + @collections_shared.sum { |c| c.items.size } %></p>
        <p class="text-xs text-gray-400 mt-1">Items</p>
      </div>
    </div>
  </div>

  <%# Mes collections %>
  <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Mes collections</h2>
  <div class="flex flex-col gap-3 mb-8">
    <% @collections_owned.each do |collection| %>
      <%= link_to collection_path(collection) do %>
        <div class="bg-white border border-gray-100 rounded-2xl p-4 active:scale-95 transition-transform duration-150">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 rounded-lg <%= Collection::CATEGORY_STYLES[collection.category] %> flex items-center justify-center shrink-0">
              <%= render "collections/icons/#{collection.category == 'books' ? 'book' : collection.category}" %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold truncate"><%= collection.title %></p>
              <p class="text-xs text-gray-400"><%= collection.items.count %> items</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>

          <% if collection.category == "video_games" %>
            <% completed = collection.items.select { |i| i.item_detailable&.completed? }.count %>
            <% incomplete = collection.items.count - completed %>
            <div class="flex gap-2">
              <div class="flex-1 bg-purple-50 rounded-xl px-3 py-3 text-center">
                <p class="text-sm font-black text-purple-600"><%= completed %></p>
                <p class="text-xs text-gray-400">Complets</p>
              </div>
              <div class="flex-1 bg-red-50 rounded-xl px-3 py-3 text-center">
                <p class="text-sm font-black text-red-400"><%= incomplete %></p>
                <p class="text-xs text-gray-400">Incomplets</p>
              </div>
              <% platforms = collection.items.map { |i| i.item_detailable&.platform }.compact.uniq.count %>
              <div class="flex-1 bg-gray-50 rounded-xl px-3 py-3 text-center">
                <p class="text-sm font-black text-gray-600"><%= platforms %></p>
                <p class="text-xs text-gray-400">Plateformes</p>
              </div>
            </div>
          <% elsif collection.category == "books" %>
            <% authors = collection.items.map { |i| i.item_detailable&.author }.compact.uniq.count %>
            <div class="flex gap-2">
              <div class="flex-1 bg-purple-50 rounded-xl px-3 py-3 text-center">
                <p class="text-sm font-black text-purple-600"><%= collection.items.count %></p>
                <p class="text-xs text-gray-400">Livres</p>
              </div>
              <div class="flex-1 bg-gray-50 rounded-xl px-3 py-3 text-center">
                <p class="text-sm font-black text-gray-600"><%= authors %></p>
                <p class="text-xs text-gray-400">Auteurs</p>
              </div>
            </div>
          <% elsif collection.category == "movies" %>
            <% formats = collection.items.map { |i| i.item_detailable&.format }.compact.uniq %>
            <div class="flex gap-2 flex-wrap">
              <% formats.each do |format| %>
                <div class="bg-gray-50 rounded-xl px-4 py-3 text-center">
                  <p class="text-xs font-semibold text-gray-600"><%= format %></p>
                </div>
              <% end %>
            </div>
          <% elsif collection.category == "music" %>
            <% formats = collection.items.map { |i| i.item_detailable&.format }.compact.uniq %>
            <div class="flex gap-2 flex-wrap">
              <% formats.each do |format| %>
                <div class="bg-gray-50 rounded-xl px-4 py-3 text-center">
                  <p class="text-xs font-semibold text-gray-600"><%= format %></p>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <% if @collections_shared.any? %>
    <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Partagées avec moi</h2>
    <div class="flex flex-col gap-2 mb-8">
      <% @collections_shared.each do |collection| %>
        <%= link_to collection_path(collection) do %>
          <div class="bg-white border border-gray-100 rounded-xl px-4 py-3 flex items-center gap-3 active:scale-95 transition-transform duration-150">
            <div class="w-8 h-8 rounded-lg <%= Collection::CATEGORY_STYLES[collection.category] %> flex items-center justify-center shrink-0">
              <%= render "collections/icons/#{collection.category == 'books' ? 'book' : collection.category}" %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold truncate"><%= collection.title %></p>
              <p class="text-xs text-gray-400"><%= collection.items.count %> items</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%# Déconnexion %>
  <%= link_to destroy_user_session_path, data: { turbo_method: :delete },
      class: "w-full flex items-center justify-center gap-2 text-red-400 border border-red-100 bg-red-50 py-3 rounded-xl text-sm font-semibold active:scale-95 transition-transform duration-150" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
    </svg>
    Se déconnecter
  <% end %>

</div>
