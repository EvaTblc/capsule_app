<div class="mt-6 min-h-screen p-4 pt-14">

  <% style = Collection::CATEGORY_STYLES[@collection.category] %>

  <div class="<%= style %> rounded-3xl p-6 mb-6 flex flex-col gap-3">
    <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center shadow-sm">
      <%= render "collections/icons/#{@collection.category}" %>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-gray-400"><%= @collection.category.humanize.titleize %></p>
      <h1 class="text-3xl font-black tracking-tight"><%= @collection.title %></h1>
    </div>
    <p class="text-sm text-gray-400"><%= @collection.items.count %> items</p>
  </div>

  <div class="flex flex-col gap-2">
    <% @items.each do |item| %>
      <%= link_to collection_item_path(@collection, item) do %>
        <div class="bg-white border border-gray-100 rounded-xl px-4 py-3 flex items-center gap-3 active:scale-95 transition-transform duration-150">
          <div class="w-8 h-8 rounded-lg bg-gray-50 flex items-center justify-center flex-shrink-0">
            <%= render "collections/icons/#{item.item_type.underscore.gsub('_detail', '')}" %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-semibold truncate"><%= item.title %></p>
            <p class="text-xs text-gray-400"><%= item.condition %></p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-300 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      <% end %>
    <% end %>
  </div>

</div>

<%= link_to new_collection_item_path(@collection), class: "fixed bottom-24 right-6 z-10 bg-purple-600 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg shadow-purple-300 active:scale-95 transition-transform duration-150" do %>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
  </svg>
<% end %>
