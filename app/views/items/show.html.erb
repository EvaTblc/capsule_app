<div class="min-h-screen p-4 pt-20 pb-24">

  <% style = Item::ITEM_TYPE_STYLES[@item.item_type] %>
  <% icon = Item::TYPE_TO_ICON[@item.item_type] %>

<div class="rounded-3xl mb-4 flex flex-col justify-end relative overflow-hidden <%= @item.images.attached? ? 'h-48' : style + ' p-6' %>"
     style="<%= @item.images.attached? ? "background-image: url('#{url_for(@item.images.first)}'); background-size: cover; background-position: center;" : "" %>">

  <% if @item.images.attached? %>
    <div class="absolute inset-0 bg-black opacity-40 rounded-3xl"></div>
  <% end %>

  <div class="relative z-10 <%= @item.images.attached? ? 'p-6' : '' %> h-full flex flex-col justify-between">
    <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center shadow-sm">
      <%= render "collections/icons/#{icon}" %>
    </div>
    <div class="flex flex-col gap-1">
      <p class="text-xs font-semibold uppercase tracking-widest <%= @item.images.attached? ? 'text-white opacity-75' : 'text-gray-400' %>"><%= @item.item_type.gsub('Detail', '').titleize %></p>
      <p class="text-xs <%= @item.images.attached? ? 'text-white opacity-75' : 'text-gray-400' %>"><%= @item.condition %></p>
      <div class="flex items-center justify-between">
        <h1 class="text-3xl font-black tracking-tight <%= @item.images.attached? ? 'text-white' : '' %>"><%= @item.title %></h1>
        <%= link_to edit_collection_item_path(@collection, @item), class: "w-9 h-9 bg-white rounded-xl flex items-center justify-center shadow-sm shrink-0" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
        <% end %>
      </div>
      <% link_color = @item.images.attached? ? 'text-white opacity-75' : 'text-gray-400' %>

    </div>
  </div>
</div>

  <%= link_to collection_path(@item.collection), class: "flex items-center gap-1 text-xs text-gray-400 mb-3" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
<%= @item.collection.title.upcase %>
  <% end %>

  <div class="bg-white border border-gray-100 rounded-2xl p-4 flex flex-col gap-3">
    <% @item.item_detailable.attributes.except("id", "created_at", "updated_at").each do |key, value| %>
      <% next if value.nil? || (value == "" ) %>

      <% if key == "description" %>
        <div class="flex justify-between items-start border-b border-gray-50 pb-2" data-controller="expandable">
          <p class="text-xs font-semibold text-gray-400 uppercase">Description</p>
          <div class="flex flex-col items-end gap-1 max-w-xs">
            <p class="text-sm font-medium text-right line-clamp-3" data-expandable-target="content"><%= value %></p>
            <button data-expandable-target="button" data-action="click->expandable#toggle" class="text-xs text-purple-600 font-semibold">Voir plus</button>
          </div>
        </div>
      <% elsif key == "completed" %>
        <div class="flex justify-between items-center border-b border-gray-50 pb-2">
          <p class="text-xs font-semibold text-gray-400 uppercase"><%= t("show.#{@item.item_type.underscore}.#{key}", default: key.humanize) %></p>
          <% if value == true %>
            <svg width="28" height="28" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="24" cy="24" r="21" stroke="#7C3AED" stroke-width="2"/>
              <path d="M14 24L21 31L34 17" stroke="#7C3AED" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          <% else %>
            <svg width="28" height="28" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="24" cy="24" r="21" stroke="#EF4444" stroke-width="2"/>
              <path d="M16 16L32 32M32 16L16 32" stroke="#EF4444" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          <% end %>
        </div>

      <% else %>
        <div class="flex justify-between items-center border-b border-gray-50 pb-2">
          <p class="text-xs font-semibold text-gray-400 uppercase"><%= t("show.#{@item.item_type.underscore}.#{key}", default: key.humanize) %></p>
          <p class="text-sm font-medium"><%= value %></p>
        </div>
      <% end %>
    <% end %>
  </div>

  <% if @item.comment.present? %>
    <div class="bg-white border border-gray-100 rounded-2xl p-4 mt-4">
      <p class="text-xs font-semibold text-gray-400 uppercase mb-2">Commentaire</p>
      <p class="text-sm text-gray-700 leading-relaxed"><%= @item.comment %></p>
    </div>
  <% end %>

  <% if @item.images.attached? %>
    <div class="grid grid-cols-2 gap-2 mb-6 mt-6" data-controller="lightbox">

      <%# Modal %>
      <div data-lightbox-target="modal" class="hidden fixed inset-0 z-50 bg-black flex items-center justify-center"
          data-action="click->lightbox#close">

        <button data-action="click->lightbox#prev"
                class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 bg-white rounded-full flex items-center justify-center z-10"
                onclick="event.stopPropagation()">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        <img data-lightbox-target="image" src="" class="max-w-full max-h-full object-contain">

        <button data-action="click->lightbox#next"
                class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 bg-white rounded-full flex items-center justify-center z-10"
                onclick="event.stopPropagation()">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>

        <button class="absolute top-4 right-4 text-white text-2xl z-10"
                data-action="click->lightbox#close"
                onclick="event.stopPropagation()">✕</button>
      </div>

      <%# Photos %>
      <% @item.images.each do |image| %>
        <div class="h-40 rounded-2xl overflow-hidden cursor-pointer"
            data-action="click->lightbox#open"
            data-url="<%= url_for(image) %>">
          <%= image_tag image, class: "w-full h-full object-cover" %>
        </div>
      <% end %>

    </div>
  <% end %>
  <div id="estimation">
    <%= button_to "Estimer la valeur", estimate_item_path(@item),
        class: "btn-estimate" %>
  </div>
</div>
