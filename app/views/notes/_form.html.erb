<div class="min-h-screen pt-10 pb-24 px-4" data-controller="carnet-toggle">

  <%# Toggle %>
  <div class="flex gap-2 bg-gray-100 rounded-2xl p-1 mb-6">
    <button type="button"
            data-action="click->carnet-toggle#showNote"
            data-carnet-toggle-target="noteBtn"
            class="flex-1 py-2 rounded-xl text-sm font-semibold transition-all duration-200 bg-white text-gray-900 shadow-sm">
      📝 Note
    </button>
    <button type="button"
            data-action="click->carnet-toggle#showEvent"
            data-carnet-toggle-target="eventBtn"
            class="flex-1 py-2 rounded-xl text-sm font-semibold transition-all duration-200 text-gray-400">
      📅 Événement
    </button>
  </div>

  <%# Titre dynamique %>
  <div class="mb-6">
    <h1 class="text-2xl font-black tracking-tight" data-carnet-toggle-target="noteTitle">Nouvelle note</h1>
    <h1 class="text-2xl font-black tracking-tight hidden" data-carnet-toggle-target="eventTitle">Nouvel événement</h1>
  </div>

  <%# Form Note %>
  <div data-carnet-toggle-target="noteForm">
    <%= form_with model: note, class: "flex flex-col gap-4" do |f| %>
      <div>
        <%= f.text_field :title,
            placeholder: "Titre",
            class: "w-full bg-gray-50 rounded-xl px-4 py-3 text-sm font-semibold text-gray-900 placeholder-gray-400 outline-none focus:ring-2 focus:ring-purple-300" %>
      </div>
      <div>
        <%= f.text_area :comment,
            placeholder: "Écris ta note ici...",
            rows: 6,
            class: "w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 outline-none focus:ring-2 focus:ring-purple-300 resize-none" %>
      </div>
      <div class="flex items-center justify-between bg-gray-50 rounded-xl px-4 py-3">
        <div>
          <p class="text-sm font-semibold text-gray-900">Reminder</p>
          <p class="text-xs text-gray-400">Mettre cette note en avant</p>
        </div>
        <%= f.check_box :reminder, class: "w-5 h-5 accent-purple-600 rounded" %>
      </div>
      <%= f.submit "Enregistrer", class: "w-full bg-purple-600 text-white py-3 rounded-xl font-semibold text-sm hover:bg-purple-700 transition-colors duration-200" %>
    <% end %>
  </div>

  <%# Form Event %>
  <div class="hidden" data-carnet-toggle-target="eventForm">
    <%= form_with model: event, class: "flex flex-col gap-4" do |f| %>
      <div>
        <%= f.text_field :title,
            placeholder: "Titre",
            class: "w-full bg-gray-50 rounded-xl px-4 py-3 text-sm font-semibold text-gray-900 placeholder-gray-400 outline-none focus:ring-2 focus:ring-purple-300" %>
      </div>
      <div>
        <%= f.date_field :date,
            class: "w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-900 outline-none focus:ring-2 focus:ring-purple-300" %>
      </div>
      <div>
        <%= f.text_field :address,
            placeholder: "Adresse ou ville",
            class: "w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 outline-none focus:ring-2 focus:ring-purple-300" %>
      </div>
      <div>
        <%= f.url_field :url,
            placeholder: "Lien (optionnel)",
            class: "w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 outline-none focus:ring-2 focus:ring-purple-300" %>
      </div>
      <div>
        <%= f.text_area :comment,
            placeholder: "Notes...",
            rows: 3,
            class: "w-full bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 outline-none focus:ring-2 focus:ring-purple-300 resize-none" %>
      </div>
      <div class="flex items-center justify-between bg-gray-50 rounded-xl px-4 py-3">
        <div>
          <p class="text-sm font-semibold text-gray-900">Reminder</p>
          <p class="text-xs text-gray-400">Me rappeler cet événement</p>
        </div>
        <%= f.check_box :reminder, class: "w-5 h-5 accent-purple-600 rounded" %>
      </div>
      <%= f.submit "Enregistrer", class: "w-full bg-purple-600 text-white py-3 rounded-xl font-semibold text-sm hover:bg-purple-700 transition-colors duration-200" %>
    <% end %>
  </div>

</div>
