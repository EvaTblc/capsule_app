      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Genre</label>
        <input data-book-search-target="genre" name="book_detail[genre]" placeholder="Genre" value="<%= book_detail&.genre %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
