<div class="min-h-screen p-4 pt-20">

  <% style = Item::ITEM_TYPE_STYLES[@item.item_type] %>
  <% icon = Item::TYPE_TO_ICON[@item.item_type] %>

  <div class="<%= style %> rounded-3xl p-6 mb-6 flex flex-col gap-3">
    <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center shadow-sm">
      <%= render "collections/icons/#{icon}" %>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-gray-400"><%= @item.item_type.gsub('Detail', '').titleize %></p>
    </div>
    <p class="text-xs text-gray-400"><%= @item.condition %></p>
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-black tracking-tight"><%= @item.title %></h1>
      <%= link_to edit_collection_item_path(@collection, @item), class: "w-9 h-9 bg-white rounded-xl flex items-center justify-center shadow-sm" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
      <% end %>
    </div>
    <%= link_to @collection, class: "flex items-center gap-1 text-xs text-gray-400 hover:text-purple-600 transition-colors duration-200 w-fit" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      <%= @collection.title %>
    <% end %>
  </div>

  <div class="bg-white border border-gray-100 rounded-2xl p-4 flex flex-col gap-3">
    <% @item.item_detailable.attributes.except("id", "created_at", "updated_at").each do |key, value| %>
      <% next if value.blank? %>
      <div class="flex justify-between items-center border-b border-gray-50 pb-2">
        <p class="text-xs font-semibold text-gray-400 uppercase"><%= key.humanize %></p>
        <p class="text-sm font-medium"><%= value %></p>
      </div>
    <% end %>
  </div>

</div>
