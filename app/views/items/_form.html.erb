      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Joueurs max</label>
        <input name="board_game_detail[max_players]" type="number" placeholder="Joueurs max" value="<%= board_game_detail&.max_players %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
      <div class="mb-4">
        <label class="text-sm font-semibold text-gray-600 mb-1 block">Durée (minutes)</label>
        <input name="board_game_detail[duration]" type="number" placeholder="Durée" value="<%= board_game_detail&.duration %>" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200">
      </div>
    </div>

    <%# Barcode %>
    <div class="mb-6">
      <label class="text-sm font-semibold text-gray-600 mb-1 block">Barcode</label>
      <%= f.text_field :barcode, placeholder: "Scanner ou saisir...", class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
    </div>

    <%# Images %>
    <div class="mb-6">
      <label class="text-sm font-semibold text-gray-600 mb-3 block">Images</label>
      <% if @item.persisted? && @item.images.attached? %>
        <div class="grid grid-cols-3 gap-2 mb-3">
          <% @item.images.each do |image| %>
            <%= link_to collection_item_path(@collection, @item, remove_image: image.id),
                data: { turbo_method: :patch, turbo_confirm: "Supprimer cette image ?" } do %>
              <div class="relative h-24 rounded-xl overflow-hidden">
                <%= image_tag image, class: "w-full h-full object-cover" %>
                <div class="absolute inset-0 flex items-center justify-center" style="background: rgba(0,0,0,0.4)">
                  <span class="text-white text-lg">🗑</span>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
      <%= f.file_field :images, accept: "image/*", multiple: true, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-400 transition-colors duration-200" %>
    </div>

    <%= f.submit "Valider", class: "w-full bg-purple-600 text-white font-semibold py-3 rounded-xl shadow-md shadow-purple-200 active:scale-95 transition-transform duration-150 mt-2" %>

  </div>
<% end %>
