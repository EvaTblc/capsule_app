<div class="min-h-screen p-4">
  <h1 class="text-2xl font-black tracking-tight mb-6">Mes collections</h1>

  <div class="flex gap-4 mb-6">
    <div class="bg-purple-50 rounded-2xl px-4 py-3 flex-1 text-center">
      <p class="text-2xl font-black text-purple-600"><%= @collections.count %></p>
      <p class="text-xs text-gray-400 mt-1">Collections</p>
    </div>
    <div class="bg-purple-50 rounded-2xl px-4 py-3 flex-1 text-center">
      <p class="text-2xl font-black text-purple-600"><%= @collections.sum { |c| c.items.count } %></p>
      <p class="text-xs text-gray-400 mt-1">Items</p>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <% @collections.each do |collection| %>
      <%= link_to collection_path(collection) do %>
        <div class="h-full item-start <%= Collection::CATEGORY_STYLES[collection.category] %> rounded-2xl p-4 shadow-md active:scale-95 transition-transform duration-150">

          <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center mb-3 shadow-sm">
            <%= render "collections/icons/#{collection.category}" %>
          </div>

          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide"><%= collection.category.humanize.titleize %></p>
          <h2 class="text-lg font-bold mt-1"><%= collection.title %></h2>
          <p class="text-xs text-gray-400 mt-2"><%= collection.items.count %> items</p>
        </div>
      <% end %>
    <% end %>
  </div>
</div>

<%= link_to new_collection_path, class: "fixed bottom-24 right-6 z-10 bg-purple-600 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg shadow-purple-300 hover:bg-purple-700 transition-colors duration-200 text-3xl" do %>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
  </svg>
<% end %>
