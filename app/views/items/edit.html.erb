<div class="min-h-screen p-4 pt-6 pb-24">
  <h1 class="text-2xl font-black tracking-tight mb-6">Modifier l'item</h1>

  <%= render "form", item: @item, collection: @collection %>

  <div class="mt-6">
    <%= link_to collection_item_path(@collection, @item),
        data: { turbo_method: :delete, turbo_confirm: "Supprimer cet item ? Cette action est irréversible." },
        class: "w-full flex items-center justify-center gap-2 text-red-400 border border-red-100 bg-red-50 py-3 rounded-xl text-sm font-semibold active:scale-95 transition-transform duration-150" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
      Supprimer l'item
    <% end %>
  </div>
</div>
